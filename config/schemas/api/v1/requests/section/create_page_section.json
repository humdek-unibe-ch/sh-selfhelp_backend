{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Create Page Section Request",
  "description": "Request schema for creating multiple sections on a page",
  "type": "array",
  "minItems": 1,
  "maxItems": 20,
  "items": {
    "type": "object",
    "properties": {
      "styleId": {
        "type": "integer"
      },
      "position": {
        "type": "integer"
      },
      "name": {
        "type": "string",
        "minLength": 1
      }
    },
    "required": ["styleId", "position"],
    "additionalProperties": false
  }
}
