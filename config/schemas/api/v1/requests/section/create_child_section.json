{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Create Child Section Request",
  "description": "Request schema for creating a new child section inside another section",
  "type": "array",
  "minItems": 1,
  "maxItems": 20,
  "items": {
    "type": "object",
    "properties": {
      "styleId": {
        "type": "integer"
      },
      "position": {
        "type": "integer"
      },
      "name": {
        "type": "string",
        "minLength": 1
      }
    }
  },
  "required": ["position", "styleId"]
}
