{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Add Sections to Page Request",
  "description": "Schema for adding one or more sections to a page",
  "type": "object",
  "properties": {
    "sections": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "sectionId": {
            "type": "integer"
          },
          "position": {
            "type": "integer"
          },
          "oldParentPageId": {
            "type": ["integer", "null"]
          },
          "oldParentSectionId": {
            "type": ["integer", "null"]
          }
        },
        "required": ["sectionId"],
        "additionalProperties": false
      }
    }
  },
  "required": ["sections"],
  "additionalProperties": false
}