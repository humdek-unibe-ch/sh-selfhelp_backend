{
    "$schema": "http://json-schema.org/draft-07/schema#",
    "title": "Update navigation settings",
    "type": "object",
    "properties": {
        "web_header_search_mode": { "type": "string" },
        "web_header_search_min_chars": { "type": "integer" },
        "web_header_search_result_limit": { "type": "integer" },
        "search_default_visibility": { "type": "string" },
        "search_field_policy": { "type": "string" },
        "web_guest_start_page_id": { "type": ["integer", "null"] },
        "web_user_start_page_id": { "type": ["integer", "null"] },
        "web_user_start_mode": { "type": "string" },
        "mobile_guest_start_page_id": { "type": ["integer", "null"] },
        "mobile_user_start_page_id": { "type": ["integer", "null"] },
        "mobile_user_start_mode": { "type": "string" },
        "mobile_start_page_source": { "type": "string" },
        "route_sync_old_route_policy": { "type": "string" },
        "logo_asset_path": { "type": ["string", "null"], "maxLength": 500 },
        "logo_alt": { "type": ["string", "null"], "maxLength": 255 },
        "logo_link_page_id": { "type": ["integer", "null"] },
        "logo_size": { "type": "string", "enum": ["sm", "md", "lg", "xl"] },
        "logo_variant": { "type": "string", "enum": ["logo-and-name", "logo-only", "name-only"] }
    },
    "additionalProperties": false
}
