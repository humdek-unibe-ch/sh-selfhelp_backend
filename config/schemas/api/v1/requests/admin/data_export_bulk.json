{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "type": "object",
  "title": "Bulk Data Export Request",
  "required": ["table_names", "format"],
  "properties": {
    "table_names": {
      "type": "array",
      "items": {"type": "string", "minLength": 1},
      "minItems": 1,
      "description": "Names of data tables to export"
    },
    "format": {
      "type": "string",
      "enum": ["csv", "json"],
      "description": "Export format"
    },
    "user_id": {
      "type": ["integer", "null"],
      "minimum": 1,
      "description": "Filter by user ID; omit or null for all users"
    },
    "language_id": {
      "type": ["integer", "null"],
      "minimum": 1,
      "description": "Language ID for translations; defaults to 1"
    },
    "exclude_deleted": {
      "type": "boolean",
      "description": "Whether to exclude soft-deleted rows; defaults to true"
    }
  },
  "additionalProperties": false
}
