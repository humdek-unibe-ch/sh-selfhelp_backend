{
    "$schema": "http://json-schema.org/draft-07/schema#",
    "title": "Create CMS App",
    "type": "object",
    "properties": {
        "name": { "type": "string", "minLength": 1, "maxLength": 150 },
        "slug": {
            "type": "string",
            "pattern": "^[a-z0-9-]+$",
            "minLength": 1,
            "maxLength": 100
        },
        "description": { "type": ["string", "null"], "maxLength": 5000 }
    },
    "required": ["name", "slug"],
    "additionalProperties": false
}
