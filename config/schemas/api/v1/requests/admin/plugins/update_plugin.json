{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "type": "object",
  "title": "Plugin Update Request",
  "additionalProperties": false,
  "required": ["manifest"],
  "properties": {
    "manifest": {
      "type": "object",
      "description": "New plugin.json contents."
    },
    "forceMajor": {
      "type": "boolean",
      "default": false,
      "description": "Acknowledge that the version diff is a major (breaking) update."
    }
  }
}
