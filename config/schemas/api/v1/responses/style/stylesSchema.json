{
    "$schema": "http://json-schema.org/draft-07/schema#",
    "title": "Styles Schema Response",
    "description": "Full style/field schema for every CMS style. Keyed by style name.",
    "type": "object",
    "allOf": [
        {
            "$ref": "../common/_response_envelope.json"
        },
        {
            "type": "object",
            "properties": {
                "data": {
                    "type": "object",
                    "description": "Map of styleName → style schema",
                    "additionalProperties": {
                        "type": "object",
                        "properties": {
                            "id": { "type": "integer" },
                            "group": { "type": "string" },
                            "can_have_children": { "type": "boolean" },
                            "description": { "type": ["string", "null"] },
                            "renderTarget": {
                                "type": "string",
                                "enum": ["web", "mobile", "both"],
                                "description": "Where this style is intentionally renderable. 'both' when id_render_target is NULL. Distinct from page access target and request client."
                            },
                            "fields": {
                                "type": "object",
                                "description": "Map of fieldName → field metadata",
                                "additionalProperties": {
                                    "type": "object",
                                    "properties": {
                                        "type": { "type": ["string", "null"] },
                                        "scope": {
                                            "type": "string",
                                            "enum": ["content", "common", "web", "mobile"],
                                            "description": "Field scope (mobile rendering plan, section 6.4). Derived centrally by the backend from translatability (display) and platform prefix; the CMS must group by this value and must not re-derive scope from the field name or display flag. content=translatable copy (display=1), common=unprefixed cross-platform behavior/data/visual property, web=web_* Mantine/browser-specific, mobile=mobile_* native-only."
                                        },
                                        "display": { "type": "integer" },
                                        "default_value": { "type": ["string", "null"] },
                                        "help": { "type": ["string", "null"] },
                                        "title": { "type": ["string", "null"] },
                                        "disabled": { "type": "boolean" },
                                        "hidden": { "type": "integer" },
                                        "placeholder": { "type": ["string", "null"] },
                                        "options": {
                                            "type": "array",
                                            "description": "Valid enum choices (empty for free-form fields). Use each item's `value` when writing JSON.",
                                            "items": {
                                                "type": "object",
                                                "properties": {
                                                    "value": { "type": "string" },
                                                    "text": { "type": "string" }
                                                },
                                                "required": ["value", "text"]
                                            }
                                        }
                                    },
                                    "required": ["type", "scope", "display", "default_value", "options"]
                                }
                            },
                            "allowed_children": {
                                "type": "array",
                                "items": { "type": "string" },
                                "description": "Allowed child style names. Empty array when can_have_children=true (any child allowed)."
                            },
                            "allowed_parents": {
                                "type": "array",
                                "items": { "type": "string" }
                            }
                        },
                        "required": ["id", "group", "can_have_children", "renderTarget", "fields", "allowed_children", "allowed_parents"]
                    }
                }
            },
            "required": ["data"]
        }
    ]
}
