{
    "$schema": "http://json-schema.org/draft-07/schema#",
    "title": "Admin Page List Response with CRUD",
    "description": "Schema for admin page responses containing CRUD permissions",
    "allOf": [
        {
            "$ref": "./_response_envelope.json"
        }
    ],
    "definitions": {
        "page": {
            "type": "object",
            "properties": {
                "id_pages": { "type": "integer" },
                "id_parent_page": { "type": ["integer", "null"] },
                "keyword": { "type": "string" },
                "url": { "type": ["string", "null"] },
                "is_headless": { "type": "boolean" },
                "is_open_access": { "type": "boolean" },
                "is_system": { "type": "boolean" },
                "id_page_access_types": { "type": "integer" },
                "id_page_types": { "type": "integer" },
                "page_surface": {
                    "type": "string",
                    "enum": ["public", "cms"],
                    "description": "CMS-in-CMS organization axis; NULL FK resolves to public"
                },
                "cms_app_id": {
                    "type": ["integer", "null"],
                    "description": "First-class CMS app this page is assigned to, or null"
                },
                "cms_app_slug": {
                    "type": ["string", "null"],
                    "description": "Slug of the assigned CMS app (UI convenience)"
                },
                "cms_app_role": {
                    "type": ["string", "null"],
                    "enum": ["form", "cms_list", "cms_detail", "public_list", "public_detail", "other", null],
                    "description": "Role of this page inside its CMS app"
                },
                "crud": { "type": "integer", "minimum": 0, "maximum": 15 },
                "title": {
                    "type": ["string", "null"],
                    "description": "Page title in the default CMS language (picker convenience)"
                },
                "titles": {
                    "type": "array",
                    "description": "Page title per language so admin pickers can label pages in the admin's current language",
                    "items": {
                        "type": "object",
                        "properties": {
                            "language_id": { "type": "integer" },
                            "title": { "type": "string" }
                        },
                        "required": ["language_id", "title"],
                        "additionalProperties": false
                    }
                },
                "navigationMembership": {
                    "type": "array",
                    "description": "Active navigation menu items referencing this page (admin navbar grouping)",
                    "items": {
                        "type": "object",
                        "properties": {
                            "menu_key": { "type": "string" },
                            "menu_item_id": { "type": "integer" },
                            "explicit": { "type": "boolean" }
                        },
                        "required": ["menu_key", "menu_item_id", "explicit"],
                        "additionalProperties": false
                    }
                }
            },
            "required": [
                "id_pages", "id_parent_page", "keyword", "url",
                "is_headless", "is_open_access",
                "is_system", "id_page_access_types", "id_page_types", "page_surface", "crud"
            ]
        }
    },
    "properties": {
        "data": {
            "type": "array",
            "items": { "$ref": "#/definitions/page" }
        }
    },
    "required": ["data"]
}
