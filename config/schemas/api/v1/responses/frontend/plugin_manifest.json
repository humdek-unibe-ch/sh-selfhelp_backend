{
    "$schema": "http://json-schema.org/draft-07/schema#",
    "title": "Plugin manifest (public)",
    "description": "Response from /cms-api/v1/plugins/manifest. Used by the frontend `PluginRuntime` and the mobile `plugins-sync` script to discover installed and enabled plugins. Anonymous + authenticated callers receive the same shape — no secrets or operation history.",
    "allOf": [
        { "$ref": "../common/_response_envelope.json" }
    ],
    "properties": {
        "data": {
            "type": "object",
            "properties": {
                "cmsVersion": { "type": "string" },
                "sdkApiVersion": { "type": "string" },
                "safeMode": { "type": "boolean" },
                "lockfileSnapshot": { "type": ["object", "null"], "additionalProperties": true },
                "plugins": {
                    "type": "array",
                    "items": {
                        "type": "object",
                        "properties": {
                            "id": { "type": "string" },
                            "pluginId": { "type": "string" },
                            "name": { "type": "string" },
                            "version": { "type": "string" },
                            "pluginApiVersion": { "type": "string" },
                            "trustLevel": { "type": "string" },
                            "enabled": { "type": "boolean" },
                            "capabilities": { "type": "array", "items": { "type": "string" } },
                            "featureFlags": { "type": "object", "additionalProperties": { "type": "boolean" } },
                            "manifest": { "type": ["object", "null"], "additionalProperties": true },
                            "frontendPackage": { "type": ["string", "null"] },
                            "frontendPackageVersion": { "type": ["string", "null"] },
                            "mobilePackage": { "type": ["string", "null"] },
                            "mobilePackageVersion": { "type": ["string", "null"] }
                        },
                        "required": ["pluginId", "name", "version", "pluginApiVersion", "enabled"],
                        "additionalProperties": true
                    }
                }
            },
            "required": ["plugins"],
            "additionalProperties": true
        }
    },
    "required": ["data"]
}
