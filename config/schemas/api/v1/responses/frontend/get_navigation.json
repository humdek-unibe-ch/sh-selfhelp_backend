{
    "$schema": "http://json-schema.org/draft-07/schema#",
    "title": "GET /navigation response data",
    "type": "object",
    "required": ["menus", "startup", "search"],
    "additionalProperties": false,
    "properties": {
        "menus": {
            "type": "object",
            "additionalProperties": {
                "type": "object",
                "required": ["key", "platform", "surface", "preset", "max_depth", "item_limit", "children_nav", "show_breadcrumbs", "items"],
                "additionalProperties": false,
                "properties": {
                    "key": {
                        "type": "string",
                        "enum": ["web_header", "web_footer", "mobile_drawer", "mobile_bottom_tabs"]
                    },
                    "platform": { "type": "string", "enum": ["web", "mobile"] },
                    "surface": { "type": "string", "enum": ["header", "footer", "drawer", "bottom_tabs"] },
                    "preset": { "type": ["string", "null"] },
                    "max_depth": { "type": ["integer", "null"] },
                    "item_limit": { "type": ["integer", "null"] },
                    "children_nav": { "enum": ["sidebar", "pills", "none", null] },
                    "show_breadcrumbs": { "type": "boolean" },
                    "items": {
                        "type": "array",
                        "items": { "$ref": "#/$defs/menuItem" }
                    }
                }
            }
        },
        "startup": { "$ref": "#/$defs/startup" },
        "search": { "$ref": "#/$defs/search" }
    },
    "$defs": {
        "pageRef": {
            "type": "object",
            "required": ["id", "keyword", "url", "title"],
            "additionalProperties": false,
            "properties": {
                "id": { "type": "integer" },
                "keyword": { "type": "string" },
                "url": { "type": ["string", "null"] },
                "title": { "type": ["string", "null"] },
                "has_content": { "type": "boolean" },
                "section_count": { "type": "integer" }
            }
        },
        "startup": {
            "type": "object",
            "required": [
                "web_guest_start_page",
                "web_user_start_page",
                "web_user_start_mode",
                "mobile_guest_start_page",
                "mobile_user_start_page",
                "mobile_user_start_mode",
                "mobile_start_page_source"
            ],
            "additionalProperties": false,
            "properties": {
                "web_guest_start_page": { "oneOf": [{ "$ref": "#/$defs/pageRef" }, { "type": "null" }] },
                "web_user_start_page": { "oneOf": [{ "$ref": "#/$defs/pageRef" }, { "type": "null" }] },
                "web_user_start_mode": {
                    "type": "string",
                    "enum": ["fixed_page", "last_visited_then_fixed_page"]
                },
                "web_user_last_visited_page": { "oneOf": [{ "$ref": "#/$defs/pageRef" }, { "type": "null" }] },
                "mobile_guest_start_page": { "oneOf": [{ "$ref": "#/$defs/pageRef" }, { "type": "null" }] },
                "mobile_user_start_page": { "oneOf": [{ "$ref": "#/$defs/pageRef" }, { "type": "null" }] },
                "mobile_user_start_mode": {
                    "type": "string",
                    "enum": ["fixed_page", "last_visited_then_fixed_page"]
                },
                "mobile_user_last_visited_page": { "oneOf": [{ "$ref": "#/$defs/pageRef" }, { "type": "null" }] },
                "mobile_start_page_source": {
                    "type": "string",
                    "enum": ["same_as_web", "custom_mobile_pages"]
                }
            }
        },
        "search": {
            "type": "object",
            "required": ["mode", "min_chars", "result_limit", "default_visibility", "field_policy"],
            "additionalProperties": false,
            "properties": {
                "mode": {
                    "type": "string",
                    "enum": ["off", "menu_pages", "searchable_pages", "content_index"]
                },
                "min_chars": { "type": "integer", "minimum": 1 },
                "result_limit": { "type": "integer", "minimum": 1 },
                "default_visibility": { "type": "string" },
                "field_policy": { "type": "string" }
            }
        },
        "menuItem": {
            "type": "object",
            "required": [
                "id",
                "item_type",
                "label",
                "description",
                "aria_label",
                "icon",
                "mobile_icon",
                "position",
                "layer",
                "children_nav",
                "external_url",
                "page",
                "is_active",
                "children"
            ],
            "additionalProperties": false,
            "properties": {
                "id": { "type": "integer" },
                "item_type": { "type": "string", "enum": ["page", "external_url", "group"] },
                "label": { "type": "string" },
                "description": { "type": ["string", "null"] },
                "aria_label": { "type": ["string", "null"] },
                "icon": { "type": ["string", "null"] },
                "mobile_icon": { "type": ["string", "null"] },
                "position": { "type": "integer" },
                "layer": { "enum": ["top", null] },
                "children_nav": { "enum": ["sidebar", "pills", "none", null] },
                "external_url": { "type": ["string", "null"] },
                "page": {
                    "oneOf": [{ "$ref": "#/$defs/pageRef" }, { "type": "null" }]
                },
                "is_active": { "type": "boolean" },
                "children": {
                    "type": "array",
                    "items": { "$ref": "#/$defs/menuItem" }
                }
            }
        }
    }
}
