{
    "$schema": "http://json-schema.org/draft-07/schema#",
    "title": "Page Version Deleted Response Schema",
    "description": "Response for DELETE /cms-api/v1/admin/pages/{page_id}/versions/{version_id} (PageVersionController::deleteVersion).",
    "type": "object",
    "allOf": [
        {
            "$ref": "../common/_response_envelope.json"
        }
    ],
    "properties": {
        "data": {
            "type": "object",
            "properties": {
                "version_id": {
                    "type": "integer",
                    "description": "ID of the deleted page version."
                },
                "message": {
                    "type": "string",
                    "description": "Human-readable success message."
                }
            },
            "required": ["version_id", "message"]
        }
    },
    "required": ["data"]
}
