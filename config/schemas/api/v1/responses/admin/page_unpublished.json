{
    "$schema": "http://json-schema.org/draft-07/schema#",
    "title": "Page Unpublished Response Schema",
    "description": "Response for POST /cms-api/v1/admin/pages/{page_id}/versions/unpublish (PageVersionController::unpublishPage) — reverts the page to draft mode.",
    "type": "object",
    "allOf": [
        {
            "$ref": "../common/_response_envelope.json"
        }
    ],
    "properties": {
        "data": {
            "type": "object",
            "properties": {
                "page_id": {
                    "type": "integer",
                    "description": "ID of the page reverted to draft."
                },
                "message": {
                    "type": "string",
                    "description": "Human-readable success message."
                }
            },
            "required": ["page_id", "message"]
        }
    },
    "required": ["data"]
}
