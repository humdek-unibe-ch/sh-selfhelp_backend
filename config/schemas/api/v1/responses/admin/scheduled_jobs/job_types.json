{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Scheduled-Job Type Catalog Response",
  "description": "Available scheduled-job types (core lookups plus plugin contributions)",
  "allOf": [
    { "$ref": "../../common/_response_envelope.json" },
    {
      "type": "object",
      "properties": {
        "data": {
          "type": "object",
          "properties": {
            "types": {
              "type": "array",
              "items": {
                "type": "object",
                "properties": {
                  "type": { "type": "string" },
                  "description": { "type": "string" },
                  "handlerServiceId": { "type": ["string", "null"] },
                  "pluginId": { "type": ["string", "null"] },
                  "configSchemaPath": { "type": ["string", "null"] }
                },
                "required": ["type", "description"]
              }
            }
          },
          "required": ["types"]
        }
      },
      "required": ["data"]
    }
  ]
}
