{
    "$schema": "http://json-schema.org/draft-07/schema#",
    "title": "Admin Page Fields Response",
    "description": "Schema for the response containing page details with its fields and translations",
    "allOf": [
        { "$ref": "../../common/_response_envelope.json" }
    ],
    "properties": {
        "data": {
            "type": "object",
            "properties": {
                "page": { "$ref": "../../../entities/pageEntity.json" },
                "fields": {
                    "type": "array",
                    "description": "List of fields associated with the page",
                    "items": { "$ref": "../../../entities/fieldEntity.json" }
                },
                "routes": {
                    "type": "array",
                    "description": "DB-driven public routes for this page (issue #30), round-tripped by the locked Routes panel",
                    "items": {
                        "type": "object",
                        "properties": {
                            "id": { "type": "integer" },
                            "path_pattern": { "type": "string" },
                            "requirements": {
                                "type": ["object", "null"],
                                "additionalProperties": { "type": "string" }
                            },
                            "is_canonical": { "type": "boolean" },
                            "is_active": { "type": "boolean" },
                            "priority": { "type": "integer" }
                        },
                        "required": ["id", "path_pattern", "is_canonical", "is_active", "priority"],
                        "additionalProperties": false
                    }
                }
            },
            "required": ["page", "fields", "routes"]
        }
    },
    "required": ["data"]
}


