{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Admin System Health Response",
  "description": "Aggregated, instance-scoped health/status (mirrors @selfhelp/shared ISystemHealth). Never contains secrets.",
  "allOf": [
    { "$ref": "../common/_response_envelope.json" }
  ],
  "properties": {
    "data": {
      "type": "object",
      "properties": {
        "instance_id": { "type": "string", "description": "Server-derived instance identity." },
        "overall": { "type": "string", "enum": ["healthy", "degraded", "down"] },
        "checked_at": { "type": "string", "description": "ISO-8601 timestamp of the check." },
        "safe_mode": { "type": "boolean" },
        "maintenance_mode": { "type": "boolean" },
        "version": {
          "type": "object",
          "properties": {
            "selfhelp": { "type": "string" },
            "backend": { "type": "string" },
            "frontend": { "type": "string" },
            "plugin_api": { "type": "string" },
            "database_migration": { "type": "string" }
          },
          "required": ["selfhelp", "backend", "frontend", "plugin_api", "database_migration"]
        },
        "update": {
          "type": "object",
          "properties": {
            "operation_id": { "type": "string" },
            "status": { "type": "string" },
            "progress_percent": { "type": "integer" }
          },
          "required": ["operation_id", "status", "progress_percent"]
        },
        "components": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "name": { "type": "string" },
              "status": {
                "type": "string",
                "enum": ["ok", "down", "degraded", "configured", "not_configured", "unknown"]
              },
              "detail": { "type": "string" }
            },
            "required": ["name", "status", "detail"]
          }
        }
      },
      "required": [
        "instance_id",
        "overall",
        "checked_at",
        "safe_mode",
        "maintenance_mode",
        "version",
        "update",
        "components"
      ]
    }
  },
  "required": ["data"]
}
