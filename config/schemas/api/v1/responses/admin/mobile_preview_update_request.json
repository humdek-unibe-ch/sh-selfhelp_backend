{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Admin System Mobile Preview Update Request Accepted Response",
  "description": "Acknowledgement that an instance-scoped mobile-preview-only update (or enable/bootstrap) was requested (202). The SelfHelp Manager performs the stateless preview swap.",
  "allOf": [
    { "$ref": "../common/_response_envelope.json" }
  ],
  "properties": {
    "data": {
      "type": "object",
      "properties": {
        "operation_id": { "type": "string" },
        "instance_id": { "type": "string" },
        "status": { "type": "string", "enum": ["requested", "approved", "running", "succeeded", "failed", "rolled_back", "rejected"] },
        "kind": { "type": "string", "enum": ["mobile-preview"] },
        "target_mobile_preview_version": { "type": "string" }
      },
      "required": ["operation_id", "instance_id", "status", "kind", "target_mobile_preview_version"]
    }
  },
  "required": ["data"]
}
