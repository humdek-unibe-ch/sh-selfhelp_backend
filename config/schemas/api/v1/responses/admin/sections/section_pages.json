{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "type": "array",
  "title": "Pages Referencing a Section",
  "items": {
    "type": "object",
    "properties": {
      "id":          { "type": "integer" },
      "keyword":     { "type": "string" },
      "isPublished": { "type": "boolean" }
    },
    "required": ["id", "keyword", "isPublished"],
    "additionalProperties": false
  }
}
