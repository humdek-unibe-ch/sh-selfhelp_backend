{
    "$schema": "http://json-schema.org/draft-07/schema#",
    "title": "Admin Section Response",
    "description": "Schema for the response containing section details with its fields and translations",
    "allOf": [
        { "$ref": "../../common/_response_envelope.json" }
    ],
    "properties": {
        "data": {
            "type": "object",
            "properties": {
                "section": { "$ref": "../../../entities/sectionEntity.json" },
                "fields": {
                    "type": "array",
                    "description": "List of fields associated with the section's style",
                    "items": {
                        "type": "object",
                        "properties": {
                            "id": { "type": "integer", "description": "Unique identifier for the field" },
                            "name": { "type": "string", "description": "Name of the field" },
                            "scope": {
                                "type": "string",
                                "enum": ["content", "common", "web", "mobile"],
                                "description": "Field scope (mobile rendering plan, section 6.4), derived centrally by the backend from translatability (display) and platform prefix: display=1 -> content; otherwise web_*/mobile_* -> web/mobile and unprefixed -> common. The CMS section inspector groups by this value and must not re-derive scope from the field name or display flag."
                            },
                            "title": { "type": "string", "description": "Title of the field" },
                            "type": { "type": ["string", "null"], "description": "Type of the field" },
                            "default_value": { "type": ["string", "null"], "description": "Default value for the field" },
                            "help": { "type": ["string", "null"], "description": "Help text for the field" },
                            "disabled": { "type": "boolean", "description": "Whether the field is disabled" },
                            "hidden": { "type": "integer", "description": "Whether the field is hidden" },
                            "display": { "type": "boolean", "description": "Whether the field is a content field (true) or property field (false)" },
                            "translations": {
                                "type": "array",
                                "description": "List of translations for this field",
                                "items": {
                                    "type": "object",
                                    "properties": {
                                        "language_id": { "type": "integer", "description": "ID of the language" },
                                        "language_code": { "type": ["string", "null"], "description": "Language code or 'property' for property fields" },
                                        "content": { "type": ["string", "null"], "description": "Translated content" },
                                        "meta": { "type": ["string", "null", "object"], "description": "Additional metadata for the translation" }
                                    },
                                    "required": ["language_id", "content"]
                                }
                            }
                        },
                        "required": ["id", "name", "scope", "title", "type", "display", "translations"]
                    }
                },
                "languages": {
                    "type": "array",
                    "description": "List of languages available for this section",
                    "items": {
                        "type": "object",
                        "properties": {
                            "id": { "type": "integer", "description": "Language ID" },
                            "locale": { "type": ["string", "null"], "description": "Language locale" }
                        },
                        "required": ["id"]
                    }
                },
                "data_table": {
                    "type": "object",
                    "description": "Present only for form sections: the data table submissions are stored in. Lets the inspector show the storage name, whether the label is admin-locked, and a deep link to the Data browser (issue #56).",
                    "properties": {
                        "id": { "type": "integer", "description": "data_tables.id" },
                        "name": { "type": "string", "description": "Immutable storage name (== form section id), used as the Data browser deep-link target" },
                        "display_name": { "type": ["string", "null"], "description": "Current human label of the data table" },
                        "locked": { "type": "boolean", "description": "True when an admin manually renamed the table (provenance 'manual'); the form section's displayName field no longer overwrites it" }
                    },
                    "required": ["id", "name", "display_name", "locked"]
                }
            },
            "required": ["section", "fields", "languages"]
        }
    },
    "required": ["data"]
}


