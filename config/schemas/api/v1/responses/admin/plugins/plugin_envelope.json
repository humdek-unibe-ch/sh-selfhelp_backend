{
    "$schema": "http://json-schema.org/draft-07/schema#",
    "title": "Single plugin envelope",
    "description": "Response from /cms-api/v1/admin/plugins/{pluginId}. Wraps the formatted plugin metadata, manifest, and capability set.",
    "allOf": [
        { "$ref": "../../common/_response_envelope.json" }
    ],
    "properties": {
        "data": {
            "type": "object",
            "properties": {
                "id": { "type": "integer" },
                "pluginId": { "type": "string" },
                "name": { "type": "string" },
                "description": { "type": ["string", "null"] },
                "version": { "type": "string" },
                "pluginApiVersion": { "type": "string" },
                "installMode": { "type": "string", "enum": ["development", "managed", "trusted"] },
                "trustLevel": { "type": "string", "enum": ["official", "reviewed", "untrusted"] },
                "enabled": { "type": "boolean" },
                "pinned": { "type": "boolean", "description": "When true the plugin is frozen at its installed version: the resolver never auto-updates it and the core update preflight treats it as a hard block until unpinned." },
                "backendPackage": { "type": ["string", "null"] },
                "backendBundleClass": { "type": ["string", "null"] },
                "frontendRuntimeUrl": { "type": ["string", "null"] },
                "frontendRuntimeStylesheetUrl": { "type": ["string", "null"] },
                "frontendRuntimeIntegrity": { "type": ["string", "null"] },
                "frontendRuntimeFormat": { "type": ["string", "null"] },
                "mobilePackage": { "type": ["string", "null"] },
                "mobilePackageVersion": { "type": ["string", "null"] },
                "manifest": { "type": "object", "additionalProperties": true },
                "capabilities": { "type": "array", "items": { "type": "string" } }
            },
            "required": ["pluginId", "name", "version", "pluginApiVersion", "enabled"],
            "additionalProperties": true
        }
    },
    "required": ["data"]
}
