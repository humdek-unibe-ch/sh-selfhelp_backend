{
    "$schema": "http://json-schema.org/draft-07/schema#",
    "title": "Plugin health report",
    "description": "Response from /cms-api/v1/admin/plugins/{pluginId}/health. Per-plugin health check aggregate.",
    "allOf": [
        { "$ref": "../../common/_response_envelope.json" }
    ],
    "properties": {
        "data": {
            "type": "object",
            "properties": {
                "pluginId": { "type": "string" },
                "version": { "type": "string" },
                "enabled": { "type": "boolean" },
                "installMode": { "type": "string" },
                "trustLevel": { "type": "string" },
                "compatibility": { "type": "object", "additionalProperties": true },
                "recentOperations": { "type": "array", "items": { "type": "object", "additionalProperties": true } },
                "pluginCheck": { "type": ["object", "null"], "additionalProperties": true },
                "checks": {
                    "type": "array",
                    "items": {
                        "type": "object",
                        "properties": {
                            "name": { "type": "string" },
                            "status": { "type": "string", "enum": ["ok", "warning", "error"] },
                            "message": { "type": "string" }
                        },
                        "required": ["name", "status"],
                        "additionalProperties": true
                    }
                }
            },
            "required": ["pluginId", "version", "checks"],
            "additionalProperties": true
        }
    },
    "required": ["data"]
}
