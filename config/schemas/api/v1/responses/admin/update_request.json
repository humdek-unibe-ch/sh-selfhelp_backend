{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Admin System Update Request Accepted Response",
  "description": "Acknowledgement that an instance-scoped update was requested (202). Mirrors @selfhelp/shared IUpdateRequestResponse data.",
  "allOf": [
    { "$ref": "../common/_response_envelope.json" }
  ],
  "properties": {
    "data": {
      "type": "object",
      "properties": {
        "operation_id": { "type": "string" },
        "instance_id": { "type": "string" },
        "status": { "type": "string", "enum": ["requested", "approved", "running", "succeeded", "failed", "rolled_back", "rejected"] }
      },
      "required": ["operation_id", "instance_id", "status"]
    }
  },
  "required": ["data"]
}
