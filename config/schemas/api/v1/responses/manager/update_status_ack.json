{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Manager Update Status Acknowledgement Response",
  "description": "Acknowledgement of a manager status write-back: the persisted lifecycle state for an operation owned by the current instance.",
  "allOf": [
    { "$ref": "../common/_response_envelope.json" }
  ],
  "properties": {
    "data": {
      "type": "object",
      "properties": {
        "operation_id": { "type": "string" },
        "instance_id": { "type": "string" },
        "status": { "type": "string" },
        "progress_percent": { "type": "integer", "minimum": 0, "maximum": 100 },
        "updated_at": { "type": "string" }
      },
      "required": [
        "operation_id",
        "instance_id",
        "status",
        "progress_percent",
        "updated_at"
      ]
    }
  },
  "required": ["data"]
}
