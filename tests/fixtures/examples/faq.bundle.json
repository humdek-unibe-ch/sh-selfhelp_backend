    "core_version": "0.1.x",
    "title": "FAQ accordion",
    "description": "Data-driven FAQ rendered as a Mantine accordion — one item per data row; managed in an admin grid.",
    "tags": [
        "cms-in-cms",
        "accordion",
        "list only",
        "translatable"
    ],
    "_comment": "CMS-in-CMS template: an FAQ app in three pages. PUBLIC: /faq renders every question as a Mantine accordion item (one item per data row via entry-list hydration). ADMIN (CMS surface): /cms/faq is an entry-table CRUD grid and /cms/faq/form is one create+edit form page with two routes (blank = create, /{record_id} = update) opened as a modal. Data binding is portable via \"@section:faq-form\" tokens; data_tables[] carries columns + sample rows (import with options.importData=true). The answer input is translatable. Content locales: de-CH + en-GB. Use a keyword + route prefix to import a second copy — in-content links are rewritten automatically. Import via Admin > Pages > Import. NOT auto-seeded.",
    "data_tables": [
        {
            "owner_section_name": "faq-form",
            "columns": [
                "question",
                "answer"
            ],
            "rows": [
                {
                    "question": "How do I reset my password?",
                    "answer": {
                        "en-GB": "Open the login page, click \"Forgot password\" and follow the email link. The link stays valid for 24 hours; afterwards simply request a new one.",
                        "de-CH": "Öffnen Sie die Anmeldeseite, klicken Sie auf «Passwort vergessen» und folgen Sie dem E-Mail-Link. Der Link ist 24 Stunden gültig; danach einfach einen neuen anfordern."
                    }
                },
                {
                    "question": "Can I use the platform on my phone?",
                    "answer": {
                        "en-GB": "Yes. Every page is responsive and the companion mobile app covers the full participant flow, including offline form entry that syncs once you are back online.",
                        "de-CH": "Ja. Jede Seite ist responsiv und die mobile App deckt den gesamten Teilnehmerablauf ab, inklusive Offline-Formularen, die nach der Verbindung synchronisiert werden."
                    }
                },
                {
                    "question": "Who can see my answers?",
                    "answer": {
                        "en-GB": "Only the study team you are enrolled with. Answers are stored per study group and are never shared across projects without your explicit consent.",
                        "de-CH": "Nur das Studienteam, bei dem Sie eingeschrieben sind. Antworten werden pro Studiengruppe gespeichert und ohne Ihre ausdrückliche Zustimmung nie zwischen Projekten geteilt."
                    }
                },
                {
                    "question": "How do I withdraw from a study?",
                    "answer": {
                        "en-GB": "Contact your study coordinator or use the withdrawal form in your profile. Your data is then excluded from future analyses in line with the study consent.",
                        "de-CH": "Wenden Sie sich an Ihre Studienkoordination oder nutzen Sie das Widerrufsformular im Profil. Ihre Daten werden dann gemäss Einwilligung von künftigen Analysen ausgeschlossen."
                    }
                },
                {
                    "question": "Which browsers are supported?",
                    "answer": {
                        "en-GB": "The two latest versions of Chrome, Firefox, Edge and Safari. Older browsers may work but are not tested.",
                        "de-CH": "Die zwei neuesten Versionen von Chrome, Firefox, Edge und Safari. Ältere Browser funktionieren eventuell, werden aber nicht getestet."
                    }
                }
            ]
        }
    ],
