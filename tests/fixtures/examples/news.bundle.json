{
    "format": "selfhelp/page-bundle",
    "version": "1.0",
    "exported_at": "2026-07-06T00:00:00+00:00",
    "core_version": "0.1.x",
    "title": "News & updates",
    "description": "Publish posts with category, date and a translatable body; public list/detail pair plus an admin grid.",
    "tags": [
        "cms-in-cms",
        "list + detail",
        "blog"
    ],
    "_comment": "CMS-in-CMS template: a News & Updates app in four pages. PUBLIC: /news lists posts as cards (category badge, date, summary) and /news/{record_id} renders the full article. ADMIN (CMS surface): /cms/news is an entry-table CRUD grid and /cms/news/form is one create+edit form page with two routes (blank = create, /{record_id} = update) opened as a modal. Data binding is portable via \"@section:news-form\" tokens; data_tables[] carries columns + sample rows (import with options.importData=true). The body input is translatable. Content locales: de-CH + en-GB. Use a keyword + route prefix to import a second copy — in-content links are rewritten automatically. Import via Admin > Pages > Import. NOT auto-seeded.",
    "data_tables": [
        {
            "owner_section_name": "news-form",
            "columns": [
                "title",
                "category",
                "published_on",
                "summary",
                "body"
            ],
            "rows": [
                {
                    "title": "New study platform goes live",
                    "category": "Release",
                    "published_on": "2026-06-01",
                    "summary": "The redesigned participant portal is now open to all study groups.",
                    "body": {
                        "en-GB": "After six months of building and testing, the redesigned participant portal is live. Every study group can now log in with their existing credentials. The new portal loads faster, works on phones, and lets coordinators publish content without writing code.",
                        "de-CH": "Nach sechs Monaten Entwicklung und Tests ist das überarbeitete Teilnehmerportal live. Alle Studiengruppen können sich mit ihren bestehenden Zugangsdaten anmelden. Das neue Portal lädt schneller, funktioniert auf dem Handy und lässt Koordinatorinnen Inhalte ohne Code veröffentlichen."
                    }
                },
                {
                    "title": "Maintenance window on Friday",
                    "category": "Notice",
                    "published_on": "2026-06-12",
                    "summary": "The platform will be read-only between 06:00 and 07:00 CET.",
                    "body": {
                        "en-GB": "We are upgrading the database cluster on Friday morning. Between 06:00 and 07:00 CET the platform stays reachable but new form submissions are paused. Drafts are kept locally and submit automatically once the window ends.",
                        "de-CH": "Am Freitagmorgen werten wir den Datenbank-Cluster auf. Zwischen 06:00 und 07:00 MEZ bleibt die Plattform erreichbar, neue Formularabgaben sind jedoch pausiert. Entwürfe werden lokal gespeichert und nach dem Fenster automatisch übermittelt."
                    }
                },
                {
                    "title": "Two new questionnaire templates",
                    "category": "Feature",
                    "published_on": "2026-06-20",
                    "summary": "Weekly mood tracking and sleep diary templates are ready to import.",
                    "body": {
                        "en-GB": "The template gallery now ships a weekly mood tracker and a structured sleep diary. Both are fully translated, mobile-friendly, and can be customised in the page editor after import.",
                        "de-CH": "Die Vorlagengalerie enthält jetzt einen wöchentlichen Stimmungs-Tracker und ein strukturiertes Schlaftagebuch. Beide sind vollständig übersetzt, mobilfreundlich und lassen sich nach dem Import im Seiteneditor anpassen."
                    }
                },
                {
                    "title": "Summer office hours",
                    "category": "Notice",
                    "published_on": "2026-07-01",
                    "summary": "Support replies within two working days during July and August.",
                    "body": {
                        "en-GB": "During July and August the support team runs a reduced schedule. Tickets are answered within two working days. Urgent incidents are still handled around the clock through the status page.",
                        "de-CH": "Im Juli und August arbeitet der Support mit reduziertem Pensum. Tickets werden innerhalb von zwei Arbeitstagen beantwortet. Dringende Vorfälle werden weiterhin rund um die Uhr über die Statusseite bearbeitet."
                    }
                }
            ]
        }
    ],
