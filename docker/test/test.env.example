# Canonical TEST environment values — copy into a local .env.test
# (which is gitignored in this repo) before running the backend suite:
#
#   cp docker/test/test.env.example .env.test
#
# CI sets the same values via the job `env:` block in
# .github/workflows/backend-tests.yml. Keep the two in sync.
#
# Loaded by Symfony Dotenv ONLY in APP_ENV=test (after .env; .env.local is
# skipped in test), so it never disturbs the dev database. The when@test
# Doctrine config appends `_test`, so the effective database is
# `selfhelp_test`; the docker MySQL grants `qa` rights on `selfhelp%`.
APP_ENV=test
APP_DEBUG=0

DATABASE_URL="mysql://qa:qa@127.0.0.1:3307/selfhelp?serverVersion=8.0&charset=utf8mb4"
REDIS_URL="redis://127.0.0.1:6380"

MERCURE_URL="http://127.0.0.1:3002/.well-known/mercure"
MERCURE_PUBLIC_URL="http://127.0.0.1:3002/.well-known/mercure"
MERCURE_JWT_SECRET="!ChangeThisTestMercureHubJWTSecretKey!"

# Allow-list for the app:test:reset-db host guard (plan §32).
TEST_DB_ALLOWED_HOSTS="127.0.0.1,localhost"
