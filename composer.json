{
    "name": "symfony/skeleton",
    "type": "project",
    "license": "MPL-2.0",
    "description": "A minimal Symfony project recommended to create bare bones applications",
    "minimum-stability": "stable",
    "prefer-stable": true,
    "require": {
        "php": ">=8.4",
        "ext-ctype": "*",
        "ext-iconv": "*",
        "doctrine/dbal": "^4.4.3",
        "doctrine/doctrine-bundle": "^3.2.2",
        "doctrine/doctrine-migrations-bundle": "^4.0",
        "doctrine/orm": "^3.6.3",
        "jfcherng/php-diff": "^7.0",
        "justinrainbow/json-schema": "^6.8",
        "jwadhams/json-logic-php": "^1.5.1",
        "lexik/jwt-authentication-bundle": "^3.2",
        "mustache/mustache": "^3.0",
        "nelmio/cors-bundle": "^2.6.1",
        "predis/predis": "^3.4.2",
        "symfony/console": "7.4.*",
        "symfony/doctrine-messenger": "7.4.*",
        "symfony/dotenv": "7.4.*",
        "symfony/flex": "^2.11",
        "symfony/framework-bundle": "7.4.*",
        "symfony/lock": "7.4.*",
        "symfony/mailer": "7.4.*",
        "symfony/mercure-bundle": "^0.4.2",
        "symfony/messenger": "7.4.*",
        "symfony/mime": "7.4.*",
        "symfony/monolog-bundle": "^4.0.2",
        "symfony/process": "7.4.*",
        "symfony/runtime": "7.4.*",
        "symfony/security-bundle": "7.4.*",
        "symfony/serializer": "7.4.*",
        "symfony/twig-bundle": "7.4.*",
        "symfony/validator": "7.4.*",
        "symfony/yaml": "7.4.*"
    },
    "config": {
        "allow-plugins": {
            "php-http/discovery": true,
            "phpstan/extension-installer": true,
            "symfony/flex": true,
            "symfony/runtime": true
        },
        "bump-after-update": true,
        "sort-packages": true
    },
    "autoload": {
        "psr-4": {
            "App\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "App\\Tests\\": "tests/"
        }
    },
    "replace": {
        "symfony/polyfill-ctype": "*",
        "symfony/polyfill-iconv": "*",
        "symfony/polyfill-php72": "*",
        "symfony/polyfill-php73": "*",
        "symfony/polyfill-php74": "*",
        "symfony/polyfill-php80": "*",
        "symfony/polyfill-php81": "*",
        "symfony/polyfill-php82": "*",
        "symfony/polyfill-php83": "*",
        "symfony/polyfill-php84": "*"
    },
    "scripts": {
        "test": "php bin/phpunit --testdox",
        "test:unit": "php bin/phpunit --testsuite=Unit",
        "test:integration": "php bin/phpunit --testsuite=Integration",
        "test:smoke": "php bin/phpunit --testsuite=Smoke --testdox",
        "test:golden": "php bin/phpunit --testsuite=Golden --testdox",
        "test:migration": "php bin/phpunit --testsuite=Integration --group=migration --testdox",
        "test:reset-db": "php bin/console app:test:reset-db --force --env=test",
        "test:coverage": "php bin/phpunit --coverage-html=build/coverage/html",
        "test:random": "php bin/phpunit --order=random",
        "test:changed": "php scripts/test-changed.php",
        "test:check-data": "php scripts/check-test-data-prefix.php",
        "test:release": [
            "@test:check-data",
            "@test:reset-db",
            "@test:unit",
            "@test:integration",
            "@test:smoke",
            "@test:golden"
        ],
        "test:nightly": [
            "@test:release",
            "@test:random",
            "@test:migration"
        ],
        "clear": "php bin/console cache:clear",
        "fresh-test-install": "php scripts/fresh-test-install.php",
        "dump": "composer dump-autoload",
        "validate-db": "php bin/console doctrine:schema:validate",
        "update-db": "php bin/console doctrine:schema:update --dump-sql",
        "dev": "php -S localhost:8000 -t public/",
        "phpstan": "phpstan analyse --memory-limit=3G",
        "headers:add": "php scripts/add-license-headers.php",
        "headers:check": "php scripts/add-license-headers.php --check",
        "headers:remove": "php scripts/add-license-headers.php --remove",
        "auto-scripts": {
            "cache:clear": "symfony-cmd",
            "assets:install %PUBLIC_DIR%": "symfony-cmd"
        },
        "post-install-cmd": [
            "@auto-scripts"
        ],
        "post-update-cmd": [
            "@auto-scripts"
        ]
    },
    "conflict": {
        "symfony/symfony": "*"
    },
    "extra": {
        "symfony": {
            "allow-contrib": false,
            "require": "7.4.*"
        }
    },
    "require-dev": {
        "dama/doctrine-test-bundle": "^8.6",
        "doctrine/doctrine-fixtures-bundle": "^4.3.1",
        "phpstan/extension-installer": "^1.4.3",
        "phpstan/phpstan": "^2.1.51",
        "phpstan/phpstan-doctrine": "^2.0.21",
        "phpstan/phpstan-symfony": "^2.0.15",
        "phpunit/phpunit": "^12.5.23",
        "shipmonk/dead-code-detector": "^1.1",
        "symfony/browser-kit": "7.4.*",
        "symfony/css-selector": "7.4.*",
        "symfony/maker-bundle": "^1.67",
        "symfony/phpunit-bridge": "^7.4.8",
        "symfony/stopwatch": "7.4.*",
        "symfony/web-profiler-bundle": "7.4.*"
    }
}
