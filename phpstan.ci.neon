# PHPStan configuration for CI (plugin-host-check workflow)
# Disables dead code detection since controllers are used via Symfony routing
# which static analysis cannot detect.

includes:
    - phpstan.dist.neon

parameters:
    shipmonkDeadCode:
        detect:
            deadMethods: false
            deadConstants: false
            deadEnumCases: false
